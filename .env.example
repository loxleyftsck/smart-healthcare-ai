##############################################
# Smart Healthcare Assistant System
# .env.example — JANGAN isi nilai asli di sini!
# Copy ke .env lalu isi sesuai environment kamu
##############################################

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
APP_NAME="Smart Health AI"
APP_ENV=local
APP_KEY=                        # generate: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_health_ai
DB_USERNAME=root
DB_PASSWORD=                    # min 16 karakter di production!

# ─────────────────────────────────────────
# JWT SECURITY (STANDAR INDUSTRI)
# ─────────────────────────────────────────
JWT_SECRET=                     # generate: php artisan jwt:secret (min 64 char)
JWT_TTL=15                      # access token: 15 MENIT (bukan 60!)
JWT_REFRESH_TTL=10080           # refresh token: 7 HARI
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true      # WAJIB true — untuk token revocation
JWT_BLACKLIST_GRACE_PERIOD=30   # 30 detik grace untuk concurrent requests

# ─────────────────────────────────────────
# PASSWORD HASHING (bcrypt)
# ─────────────────────────────────────────
BCRYPT_ROUNDS=12                # cost factor 12 = ~250ms (aman + tidak terlalu lambat)

# ─────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────
RATE_LIMIT_LOGIN=5              # max 5 percobaan login
RATE_LIMIT_LOGIN_WINDOW=15      # per 15 menit
RATE_LIMIT_REGISTER=10          # max 10 register
RATE_LIMIT_REGISTER_WINDOW=60   # per 60 menit
RATE_LIMIT_API=60               # max 60 request API (authenticated)
RATE_LIMIT_API_WINDOW=1         # per 1 menit

# ─────────────────────────────────────────
# ACCOUNT LOCKOUT
# ─────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5            # lock setelah 5 gagal
LOGIN_LOCKOUT_MINUTES=15        # lock selama 15 menit
LOGIN_HARD_LOCK_ATTEMPTS=20     # permanent lock di 20 gagal

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production: CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─────────────────────────────────────────
# SESSION
# ─────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=15             # 15 menit (sesuai JWT TTL)
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false     # true di production (HTTPS)
SESSION_SAME_SITE=lax

# ─────────────────────────────────────────
# LOGGING & MONITORING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug                 # production: warning atau error
LOG_DEPRECATIONS_CHANNEL=null

# ─────────────────────────────────────────
# DATASET PATHS (Triage & Chatbot)
# ─────────────────────────────────────────
TRIAGE_RULES_PATH=datasets/triage_rules.json
INTENTS_PATH=datasets/intents.json
RESPONSES_PATH=datasets/responses.json

# ─────────────────────────────────────────
# MAIL (untuk alert & reset password)
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@smarthealthai.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# CACHE & QUEUE
# ─────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync           # production: redis atau database

# ─────────────────────────────────────────
# PRODUCTION SECURITY (uncomment di production)
# ─────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# BCRYPT_ROUNDS=14
# SESSION_SECURE_COOKIE=true
# LOG_LEVEL=warning
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
